@model CampusServicesApp.Models.StatusHistory
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = "Status History Details";
    var roleName = HttpContextAccessor.HttpContext?.Session.GetString("RoleName")?.Trim();
    var isManager = string.Equals(roleName, "Manager", StringComparison.OrdinalIgnoreCase);
    var isAdmin = string.Equals(roleName, "Admin", StringComparison.OrdinalIgnoreCase);
}

<h1>Status History Details</h1>

<div>
    <h4>Status History Information</h4>
    <hr />
    <dl class="row">
        @if (!string.IsNullOrWhiteSpace(Model.OldStatus))
        {
            <dt class="col-sm-2">Old Status</dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.OldStatus)
            </dd>
        }

        <dt class="col-sm-2">Current Status</dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.NewStatus)
        </dd>

        <dt class="col-sm-2">Changed At</dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ChangedAt)
        </dd>

        <dt class="col-sm-2">Changed By</dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ChangedByNavigation.Name)
        </dd>

        <dt class="col-sm-2">Service Request</dt>
        <dd class="col-sm-10">
            <span class="badge bg-primary">@Model.Request.TrackingNumber</span>
        </dd>
    </dl>
</div>

<div class="mt-3">
    @if (isManager || isAdmin)
    {
        <a asp-action="Edit" asp-route-id="@Model?.StatusHistoryId" class="btn btn-primary">Edit</a>
    }
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>