@model CampusServicesApp.Models.StatusHistory

@{
    ViewData["Title"] = "Delete Status Entry";
}

<h1>Delete Status Entry</h1>

<h3>Are you sure you want to delete this status entry?</h3>
<div>
    <h4>Status History</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Old Status</dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.OldStatus)
        </dd>

        <dt class="col-sm-2">New Status</dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.NewStatus)
        </dd>

        <dt class="col-sm-2">Changed At</dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ChangedAt)
        </dd>

        <dt class="col-sm-2">Changed By</dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ChangedByNavigation.Name)
        </dd>

        <dt class="col-sm-2">Service Request</dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Request.TrackingNumber)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="StatusHistoryId" />
        <input type="submit" value="Delete Status Entry" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>