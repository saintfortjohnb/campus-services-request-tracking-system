@model CampusServicesApp.Models.StatusHistory

@{
    ViewData["Title"] = "Create Status History";
}

<h1>Create Status History</h1>
    
<h4>Status History</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="All" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="RequestId" class="control-label">Service Request</label>
                <select asp-for="RequestId" class="form-control" asp-items="ViewBag.RequestId">
                    <option value="">-- Select Request --</option>
                </select>
                <span asp-validation-for="RequestId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="OldStatus" class="control-label">Old Status</label>
                <input asp-for="OldStatus" class="form-control" />
                <span asp-validation-for="OldStatus" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="NewStatus" class="control-label">New Status</label>
                <input asp-for="NewStatus" class="form-control" />
                <span asp-validation-for="NewStatus" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ChangedBy" class="control-label">Changed By</label>
                <select asp-for="ChangedBy" class="form-control" asp-items="ViewBag.ChangedBy">
                    <option value="">-- Select User --</option>
                </select>
                <span asp-validation-for="ChangedBy" class="text-danger"></span>
            </div>
            <div class="form-group mt-3">
                <input type="submit" value="Create Status Entry" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}