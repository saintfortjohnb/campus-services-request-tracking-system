@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container mt-4">
    <h1>Privacy Policy</h1>
    <p class="text-muted">Last updated: @DateTime.Now.ToString("MMMM dd, yyyy")</p>

    <hr />

    <h4>Overview</h4>
    <p>
        The Campus Services Request & Tracking System is designed to manage and track service requests within a controlled campus environment. This system collects only the necessary information required to process and resolve service requests efficiently.
    </p>

    <h4>Information Collected</h4>
    <ul>
        <li>User names and contact information</li>
        <li>Service request details and descriptions</li>
        <li>Status updates and assignment history</li>
    </ul>

    <h4>Use of Information</h4>
    <p>
        The information collected is used solely for operational purposes, including request tracking, assignment management, and service resolution. No personal data is shared with external parties.
    </p>

    <h4>Data Security</h4>
    <p>
        We implement standard security practices to protect system data and ensure that access is restricted to authorized users only.
    </p>

    <h4>Contact</h4>
    <p>
        For any questions regarding this privacy policy, please contact the system administrator.
    </p>

    <div class="mt-4">
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Back to Home</a>
    </div>
</div>
