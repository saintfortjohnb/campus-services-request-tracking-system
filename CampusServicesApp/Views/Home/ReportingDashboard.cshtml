@model CampusServicesApp.Models.ReportingDashboardViewModel

@{
    ViewData["Title"] = "Reporting Dashboard";
}

<h1 class="mb-4">Reporting Dashboard</h1>

<form asp-controller="Home" asp-action="ExportCsv" method="get" class="card shadow-sm mb-4">
    <div class="card-body">
        <h5 class="card-title mb-3">Export Filters</h5>
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label for="status" class="form-label">Status</label>
                <select id="status" name="status" class="form-select">
                    <option value="">All Statuses</option>
                    @foreach (var status in Model.RequestsByStatus.Keys.OrderBy(s => s))
                    {
                        <option value="@status">@status</option>
                    }
                </select>
            </div>

            <div class="col-md-3">
                <label for="categoryName" class="form-label">Category</label>
                <select id="categoryName" name="categoryName" class="form-select">
                    <option value="">All Categories</option>
                    @foreach (var category in Model.RequestsByCategory.Keys.OrderBy(c => c))
                    {
                        <option value="@category">@category</option>
                    }
                </select>
            </div>

            <div class="col-md-2">
                <label for="startDate" class="form-label">Start Date</label>
                <input id="startDate" name="startDate" type="date" class="form-control" />
            </div>

            <div class="col-md-1">
                <label for="endDate" class="form-label">End Date</label>
                <input id="endDate" name="endDate" type="date" class="form-control" />
            </div>

            <div class="col-md-1 d-grid">
                <button type="submit" class="btn btn-outline-primary">Export CSV</button>
            </div>

            <div class="col-md-1 d-grid">
                <button type="submit"
                        formaction="@Url.Action("ExportPdf", "Home")"
                        formmethod="get"
                        class="btn btn-outline-danger">
                    Export PDF
                </button>
            </div>
        </div>
    </div>
</form>

<div class="row">
    <div class="col-md-4">
        <div class="card text-white bg-primary mb-3">
            <div class="card-body text-center">
                <h5 class="card-title">Open Requests</h5>
                <h2>@Model.OpenCount</h2>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card text-white bg-success mb-3">
            <div class="card-body text-center">
                <h5 class="card-title">Resolved Requests</h5>
                <h2>@Model.ResolvedCount</h2>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card text-white bg-dark mb-3">
            <div class="card-body text-center">
                <h5 class="card-title">Closed Requests</h5>
                <h2>@Model.ClosedCount</h2>
            </div>
        </div>
    </div>
</div>

<div class="mt-4 d-flex justify-content-between align-items-center">
    <h4>Requests by Category</h4>
</div>

<table class="table table-striped table-bordered">
    <thead class="table-light">
        <tr>
            <th>Category</th>
            <th>Count</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model.RequestsByCategory)
    {
        <tr>
            <td>@item.Key</td>
            <td>@item.Value</td>
        </tr>
    }
    </tbody>
</table>

<div class="mt-5">
    <h4>Requests by Status</h4>
    <table class="table table-striped table-bordered">
        <thead class="table-light">
            <tr>
                <th>Status</th>
                <th>Count</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model.RequestsByStatus)
        {
            <tr>
                <td>@item.Key</td>
                <td>@item.Value</td>
            </tr>
        }
        </tbody>
    </table>
</div>

<div class="mt-3">
    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Back to Home</a>
</div>