@model CampusServicesApp.Models.Assignment

@{
    ViewData["Title"] = "Delete Assignment";
}

<h1>Delete Assignment</h1>

<h3>Are you sure you want to delete this assignment?</h3>
<div>
    <h4>Assignment Details</h4>
    <hr />
        <dl class="row">
        <dt class="col-sm-2">Assigned At</dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.AssignedAt)
        </dd>

        <dt class="col-sm-2">Assigned By</dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.AssignedByNavigation.Name)
        </dd>

        <dt class="col-sm-2">Service Request</dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Request.TrackingNumber)
        </dd>

        <dt class="col-sm-2">Technician</dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Technician.Name)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="AssignmentId" />
        <input type="submit" value="Delete Assignment" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>
