@model CampusServicesApp.Models.ServiceTeam

@{
    ViewData["Title"] = "Service Team Details";
}

<h1>Service Team Details</h1>

<div>
    <h4>Team Information</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Team Name</dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.TeamName)
        </dd>

        <dt class="col-sm-2">Team Email</dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.TeamEmail)
        </dd>

        <dt class="col-sm-2">Active</dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.IsActive)
        </dd>
    </dl>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model?.TeamId" class="btn btn-primary">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>