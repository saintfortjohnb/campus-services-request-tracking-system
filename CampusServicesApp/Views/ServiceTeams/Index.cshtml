@model IEnumerable<CampusServicesApp.Models.ServiceTeam>

@{
    ViewData["Title"] = "Service Teams";
}

<h1>Service Teams</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Team</a>
</p>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Team Name</th>
            <th>Email</th>
            <th>Active</th>
            <th style="width: 180px;">Actions</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.TeamName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.TeamEmail)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.IsActive)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.TeamId" class="btn btn-sm btn-primary">Edit</a>
                <a asp-action="Details" asp-route-id="@item.TeamId" class="btn btn-sm btn-info">Details</a>
                <a asp-action="Delete" asp-route-id="@item.TeamId" class="btn btn-sm btn-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>