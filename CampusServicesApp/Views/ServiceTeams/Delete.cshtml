@model CampusServicesApp.Models.ServiceTeam

@{
    ViewData["Title"] = "Delete Service Team";
}

<h1>Delete Service Team</h1>

<h3>Are you sure you want to delete this team?</h3>

<div>
    <h4>Team Details</h4>
    <hr />

    <div asp-validation-summary="All" class="text-danger"></div>

    <dl class="row">
        <dt class="col-sm-2">Team Name</dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.TeamName)
        </dd>

        <dt class="col-sm-2">Team Email</dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.TeamEmail)
        </dd>

        <dt class="col-sm-2">Active</dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.IsActive)
        </dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="TeamId" />
        <input type="submit" value="Delete Team" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>