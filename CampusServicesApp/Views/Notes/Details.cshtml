@model CampusServicesApp.Models.Note

@{
    ViewData["Title"] = "Note Details";
}

<h1>Note Details</h1>

<div>
    <h4>Work Log Entry</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Service Request</dt>
        <dd class="col-sm-10">
            @(Model.Request != null ? Model.Request.TrackingNumber : "")
        </dd>

        <dt class="col-sm-2">Author</dt>
        <dd class="col-sm-10">
            @(Model.Author != null ? Model.Author.Name : "")
        </dd>

        <dt class="col-sm-2">Created At</dt>
        <dd class="col-sm-10">
            @Model.CreatedAt.ToString("g")
        </dd>

        <dt class="col-sm-2">Note</dt>
        <dd class="col-sm-10">
            @Model.NoteText
        </dd>
    </dl>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.NoteId" class="btn btn-primary">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>