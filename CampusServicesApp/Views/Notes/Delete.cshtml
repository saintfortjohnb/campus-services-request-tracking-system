@model CampusServicesApp.Models.Note

@{
    ViewData["Title"] = "Delete Note";
}

<h1>Delete Note</h1>

<h3>Are you sure you want to delete this note?</h3>

<div>
    <h4>Work Log Entry</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Service Request</dt>
        <dd class="col-sm-10">
            @(Model.Request != null ? Model.Request.TrackingNumber : "")
        </dd>

        <dt class="col-sm-2">Author</dt>
        <dd class="col-sm-10">
            @(Model.Author != null ? Model.Author.Name : "")
        </dd>

        <dt class="col-sm-2">Created At</dt>
        <dd class="col-sm-10">
            @Model.CreatedAt.ToString("g")
        </dd>

        <dt class="col-sm-2">Note</dt>
        <dd class="col-sm-10">
            @Model.NoteText
        </dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="NoteId" />
        <input type="submit" value="Delete Note" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>