@model CampusServicesApp.Models.Note

@{
    ViewData["Title"] = "Edit Note";
}

<h1>Edit Note</h1>

<h4>Work Log Entry</h4>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <div asp-validation-summary="All" class="text-danger"></div>
            <input type="hidden" asp-for="NoteId" />
            <input type="hidden" asp-for="RequestId" />
            <input type="hidden" asp-for="AuthorId" />
            <input type="hidden" asp-for="CreatedAt" />

            <div class="form-group">
                <label class="control-label">Service Request</label>
                <div>
                    <span class="badge bg-primary">@(Model.Request != null ? Model.Request.TrackingNumber : $"Request #{Model.RequestId}")</span>
                </div>
            </div>

            <div class="form-group mt-2">
                <label class="control-label">Author</label>
                <div>
                    <span class="badge bg-secondary">@(Model.Author != null ? Model.Author.Name : $"User #{Model.AuthorId}")</span>
                </div>
            </div>

            <div class="form-group mt-2">
                <label class="control-label">Created At</label>
                <div>
                    <span class="form-control-plaintext">@Model.CreatedAt.ToString("g")</span>
                </div>
            </div>

            <div class="form-group mt-2">
                <label asp-for="NoteText" class="control-label">Note</label>
                <textarea asp-for="NoteText" class="form-control" rows="5"></textarea>
                <span asp-validation-for="NoteText" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Save Changes" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}