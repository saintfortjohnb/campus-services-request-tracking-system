@model CampusServicesApp.Models.Note

@{
    ViewData["Title"] = "Add Note";
}

<h1>Add Note</h1>

<h4>Work Log Entry</h4>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="form-group">
                <label class="control-label">Service Request</label>
                <div>
                    <span class="badge bg-primary">@ViewBag.TrackingNumber</span>
                </div>
                <input type="hidden" asp-for="RequestId" />
            </div>

            <div class="form-group mt-2">
                <label asp-for="NoteText" class="control-label">Note</label>
                <textarea asp-for="NoteText" class="form-control" rows="5"></textarea>
                <span asp-validation-for="NoteText" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Save Note" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-controller="ServiceRequests" asp-action="Details" asp-route-id="@Model.RequestId" class="btn btn-secondary">Back to Request</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}