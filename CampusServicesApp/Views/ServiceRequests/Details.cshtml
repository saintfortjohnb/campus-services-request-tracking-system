@model CampusServicesApp.Models.ServiceRequest
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = "Service Request Details";

    var roleName = HttpContextAccessor.HttpContext?.Session.GetString("RoleName")?.Trim();
    var currentUserId = HttpContextAccessor.HttpContext?.Session.GetInt32("UserId");
    var isAdmin = string.Equals(roleName, "Admin", StringComparison.OrdinalIgnoreCase);
    var isManager = string.Equals(roleName, "Manager", StringComparison.OrdinalIgnoreCase);
    var isTechnician = string.Equals(roleName, "Technician", StringComparison.OrdinalIgnoreCase);
    var isRequesterForThisRequest = currentUserId.HasValue && currentUserId.Value == Model.RequesterId;
}

<h1>Service Request Details</h1>

<div class="d-flex justify-content-between align-items-center">
    <h4 class="mb-0">Service Request Information</h4>
    <div class="d-flex gap-2">
        <a asp-action="ExportRequestCsv"
           asp-route-id="@Model.RequestId"
           class="btn btn-outline-primary btn-sm">
            Export CSV
        </a>
        <a asp-action="ExportRequestPdf"
           asp-route-id="@Model.RequestId"
           class="btn btn-outline-danger btn-sm">
            Export PDF
        </a>
    </div>
</div>
<hr />
<div>
    <dl class="row">
        <dt class="col-sm-2">Tracking Number</dt>
        <dd class="col-sm-10">
            <span class="badge bg-primary">@Model.TrackingNumber</span>
        </dd>

        <dt class="col-sm-2">Current Status</dt>
        <dd class="col-sm-10">
            @Model.CurrentStatus
        </dd>

        <dt class="col-sm-2">Category</dt>
        <dd class="col-sm-10">
            @Model.Category?.CategoryName
        </dd>

        <dt class="col-sm-2">Requester</dt>
        <dd class="col-sm-10">
            @Model.Requester?.Name
        </dd>

        <dt class="col-sm-2">Created At</dt>
        <dd class="col-sm-10">
            @Model.CreatedAt
        </dd>

        <dt class="col-sm-2">Description</dt>
        <dd class="col-sm-10">
            <div class="border rounded p-2 bg-light">
                @Model.Description
            </div>
        </dd>
    </dl>
</div>

<hr />
<div class="mt-4">
    <h4>Work Log / Notes</h4>

    @if (isTechnician || isManager || isAdmin || isRequesterForThisRequest)
    {
        <p>
            <a asp-controller="Notes"
               asp-action="Create"
               asp-route-requestId="@Model.RequestId"
               class="btn btn-primary btn-sm">
                Add Note
            </a>
        </p>
    }

    @if (Model.Notes != null && Model.Notes.Any())
    {
        <table class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th>Created At</th>
                    <th>Author</th>
                    <th>Note</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var note in Model.Notes.OrderByDescending(n => n.CreatedAt))
                {
                    <tr>
                        <td>@note.CreatedAt.ToString("g")</td>
                        <td>@(note.Author != null ? note.Author.Name : "")</td>
                        <td>@note.NoteText</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p>No notes have been added yet.</p>
    }
</div>

<div class="mt-3">
    @if (isTechnician || isManager || isAdmin)
    {
        <a asp-action="Edit" asp-route-id="@Model?.RequestId" class="btn btn-primary">Edit</a>
    }

    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>