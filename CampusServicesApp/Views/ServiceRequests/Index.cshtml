@model IEnumerable<CampusServicesApp.Models.ServiceRequest>
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = ViewData["Title"] ?? "Open Requests";

    var roleName = HttpContextAccessor.HttpContext?.Session.GetString("RoleName")?.Trim();
    var isAdmin = string.Equals(roleName, "Admin", StringComparison.OrdinalIgnoreCase);
    var isManager = string.Equals(roleName, "Manager", StringComparison.OrdinalIgnoreCase);
    var isTechnician = string.Equals(roleName, "Technician", StringComparison.OrdinalIgnoreCase);
    var isRequester = string.Equals(roleName, "Requester", StringComparison.OrdinalIgnoreCase);
}

<h1>@ViewData["Title"]</h1>

<p>
    @if (isRequester || isTechnician || isManager || isAdmin)
    {
        <a asp-action="Create" class="btn btn-primary">Create New Request</a>
    }

    <a asp-action="Index" class="btn btn-secondary">Open Requests</a>
    <a asp-action="Resolved" class="btn btn-success">Resolved Requests</a>
    <a asp-action="Closed" class="btn btn-dark">Closed Requests</a>

    @if (isTechnician)
    {
        <a asp-action="MyAssignments" class="btn btn-warning">My Assigned Requests</a>
    }
</p>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Tracking Number</th>
            <th>Current Status</th>
            <th>Description</th>
            <th>@(ViewData["Title"]?.ToString() == "Closed Requests" ? "Closed At" : "Created At")</th>
            <th>Category</th>
            <th>Requester</th>
            @if (!string.IsNullOrEmpty(roleName))
            {
                <th style="width: 220px;">Actions</th>
            }
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>
                <span class="badge bg-primary">@item.TrackingNumber</span>
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CurrentStatus)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Description)
            </td>
            <td>
                @(ViewData["Title"]?.ToString() == "Closed Requests"
                    ? item.ClosedAt?.ToString("g")
                    : item.CreatedAt.ToString("g"))
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Category.CategoryName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Requester.Name)
            </td>
            @if (!string.IsNullOrEmpty(roleName))
            {
                <td>
                    <a asp-action="Details" asp-route-id="@item.RequestId" class="btn btn-sm btn-info">Details</a>

                    @if (isTechnician || isManager || isAdmin)
                    {
                        <a asp-action="Edit" asp-route-id="@item.RequestId" class="btn btn-sm btn-primary">Edit</a>
                    }

                    @if (isManager || isAdmin)
                    {
                        <a asp-action="Delete" asp-route-id="@item.RequestId" class="btn btn-sm btn-danger">Delete</a>
                    }
                </td>
            }
        </tr>
}
    </tbody>
</table>